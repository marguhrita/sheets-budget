# Google Cloud OAuth client (create at https://console.cloud.google.com/apis/credentials
# as an "OAuth client ID" of type "Desktop app" or "Web application", with the
# Google Sheets API and Google Drive API enabled on the project).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Only needed for local/dev HTTP testing without a trusted TLS cert.
# Never set this in production.
OAUTHLIB_INSECURE_TRANSPORT=1

# Which Google services the MCP server exposes. Keep this scoped to just
# what this project needs.
WORKSPACE_MCP_TOOLS=sheets,drive

# core | extended | complete — how many tools per service are loaded.
WORKSPACE_MCP_TOOL_TIER=core

# Port the server listens on.
WORKSPACE_MCP_PORT=8000

# Container-friendly mode: don't rely on a local browser for the OAuth
# redirect; print/return the auth URL instead.
WORKSPACE_MCP_STATELESS_MODE=false
